---
// Compact provider strip for the homepage: a logo + short-name chip per provider,
// linking to its overview. Driven by src/data/providers.json (generated by
// scripts/sync-providers.mjs from the providers in the repo), so it lists exactly
// the same set as the /providers/ index and can never drift. Logos render via
// <img> (not inline SVG) so a provider's SVG can't execute script.
import providers from "../data/providers.json";

const shortName = (title) => title.replace(/\s+provider$/i, "");
---

<div class="provider-strip not-content">
  {
    providers.map((p) => (
      <a class="provider-chip" href={p.href}>
        {p.logo ? (
          <>
            <img
              class="provider-chip-logo provider-chip-logo--light"
              src={p.logo}
              alt=""
              loading="lazy"
            />
            {p.logoDark && (
              <img
                class="provider-chip-logo provider-chip-logo--dark"
                src={p.logoDark}
                alt=""
                loading="lazy"
              />
            )}
          </>
        ) : (
          <span
            class="provider-chip-logo provider-chip-logo--fallback"
            aria-hidden="true"
          >
            {p.title.slice(0, 1)}
          </span>
        )}
        <span class="provider-chip-name">{shortName(p.title)}</span>
      </a>
    ))
  }
</div>
