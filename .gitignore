# Build artifacts
/bin/
*.exe
*.test
*.out
# Provider binaries left at the repo root by a bare `go build ./providers/<name>`
# (the sanctioned build path is `make build-<name>`, which writes to bin/).
/_template
/providers/*/*.bin

# Conformance scratch (cloned bigfleet checkout, local provider state)
/.cache/
*.state.json

# Local credentials / TLS material — never commit these
*.pem
*.key
*.crt
/secrets/
.env
.env.*

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
