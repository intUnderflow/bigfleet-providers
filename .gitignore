# Build artifacts. Build providers with `make build-<name>`, which writes to
# bin/. A bare `go build ./...` inside a provider module drops a binary named
# after the module dir; if you see one in `git status`, you ran a bare build —
# delete it (don't commit it).
/bin/
*.exe
*.test
*.out

# Conformance scratch (cloned bigfleet checkout, local provider state)
/.cache/
*.state.json

# Local Go workspace (editor convenience only, generated by `make gen-workspace`).
# Builds use per-module replace directives, so go.work is never committed —
# committing it would re-introduce a shared file every new provider must edit.
/go.work
/go.work.sum

# Local credentials / TLS material — never commit these
*.pem
*.key
*.crt
/secrets/
.env
.env.*

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
