# Build artifacts
/bin/
*.exe
*.test
*.out
# Provider binaries left by a bare `go build ./providers/<name>` (at the repo
# root) or `go build` inside a provider dir. The sanctioned build path is
# `make build-<name>`, which writes to bin/.
/_template
/aws
/providers/*/*.bin
/providers/aws/aws

# Conformance scratch (cloned bigfleet checkout, local provider state)
/.cache/
*.state.json

# Local credentials / TLS material — never commit these
*.pem
*.key
*.crt
/secrets/
.env
.env.*

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
