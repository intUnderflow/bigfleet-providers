/* Least-privilege libvirt access for the BigFleet libvirt provider.
 *
 * Install on each managed host as
 *   /etc/polkit-1/rules.d/49-bigfleet-libvirt.rules
 * then `systemctl restart polkit`.
 *
 * It grants the dedicated `bigfleet` user (member of the `libvirt` group)
 * permission to manage domains and storage through the SYSTEM libvirtd API
 * without a password prompt — and nothing else. The provider connects as this
 * user over qemu+ssh:// (or its client cert maps to a session subject under
 * qemu+tls://). Scope the storage pool and network the provider uses
 * (--storage-pool / --network) to BigFleet-managed resources so this access
 * cannot reach other tenants' VMs.
 */
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("org.libvirt.unix.manage") === 0 &&
        subject.isInGroup("libvirt") &&
        subject.user === "bigfleet") {
        return polkit.Result.YES;
    }
});
